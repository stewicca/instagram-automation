# Instagram
INSTAGRAM_ACCESS_TOKEN=your_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_account_id

# AI Model Config
USE_LOCAL_LLM=true

# Anthropic (Production)
ANTHROPIC_API_KEY=sk-ant-placeholder

# Ollama (development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/instagram_automation

# Redis
REDIS_URL=redis://localhost:6379

# Telegram Bot (optional — untuk notifikasi)
# TELEGRAM_BOT_TOKEN=bot_token_dari_botfather
# TELEGRAM_CHAT_ID=chat_id_kamu

# Gemini API - Image Generation (Fase 6)
# GEMINI_API_KEY=AIza...

# Cloud Storage (Fase 6)
UPLOAD_STORAGE=local
LOCAL_UPLOAD_PATH=./uploads
# UPLOAD_BASE_URL=https://cdn.yourdomain.com

# Meta Ads API (Fase 7 - optional)
# META_ADS_ACCOUNT_ID=act_XXXXXX
# META_ADS_ACCESS_TOKEN=your_ads_token

# HTTP Server (Fase 8)
PORT=3000

# Langfuse - Observability (optional)
# Daftar gratis di https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
